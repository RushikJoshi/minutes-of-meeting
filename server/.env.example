## Server required
MONGO_URI=mongodb://127.0.0.1:27017/mom
PORT=5000
JWT_SECRET=change_me_to_a_long_random_string

## Used for PDF image embedding + share links (optional but recommended)
PUBLIC_API_BASE_URL=http://localhost:5000

## Microsoft 365 / Outlook Calendar (Graph OAuth)
MS_CLIENT_ID=your_azure_app_client_id
MS_CLIENT_SECRET=your_azure_app_client_secret
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:5000/integrations/microsoft/callback

## Where to redirect after Microsoft OAuth completes
PUBLIC_CLIENT_BASE_URL=http://localhost:5173

## Reminders poll interval (ms)
REMINDER_POLL_MS=60000

